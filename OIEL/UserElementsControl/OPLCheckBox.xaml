<Base:IELContainerBase
    x:Class="OPLAPI.OIEL.UserElementsControl.OPLCheckBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Base="clr-namespace:IEL.UserElementsControl.Base;assembly=LibraryIEL"
    xmlns:IEL="clr-namespace:IEL.UserElementsControl;assembly=LibraryIEL" HorizontalAlignment="Left" VerticalAlignment="Top" Cursor="Hand">
    <Grid x:FieldModifier="private" x:Name="MainContainer">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Border x:FieldModifier="private" x:Name="BorderCheck" BorderThickness="2,2,2,2" CornerRadius="5,5,5,5" BorderBrush="Black" Width="{Binding ActualHeight, ElementName=ViewBoxText}" Height="{Binding ActualHeight, ElementName=ViewBoxText}" Margin="2,2,2,2" Padding="2,2,2,2">
            <Rectangle x:FieldModifier="private" x:Name="RectangleCheck" RadiusX="3" RadiusY="3" Fill="Black"/>
        </Border>
        <Viewbox x:FieldModifier="private" x:Name="ViewBoxText" Grid.Column="1" Margin="0,3,0,3" HorizontalAlignment="Left" StretchDirection="DownOnly" Stretch="UniformToFill">
            <TextBlock x:FieldModifier="private" x:Name="TextBlockElement" Text="Name" Padding="3,2,5,2"/>
        </Viewbox>
    </Grid>
</Base:IELContainerBase>
