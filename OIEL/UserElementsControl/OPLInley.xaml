<Base:IELContainerBase
    x:Class="OPLAPI.OIEL.UserElementsControl.OPLInlay"
    xmlns:Base="clr-namespace:IEL.UserElementsControl.Base;assembly=LibraryIEL"
    xmlns:OIEL="clr-namespace:OPLAPI.OIEL.UserElementsControl;assembly=OPLAPI"
    xmlns:IEL="clr-namespace:IEL.UserElementsControl;assembly=LibraryIEL"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:OPLAPI.OIEL.UserElementsControl" Cursor="Hand">
    <Grid x:Name="MainGridElement" HorizontalAlignment="Right">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Viewbox StretchDirection="DownOnly">
            <TextBlock x:Name="TextBlockHead" Text="Text" VerticalAlignment="Center" FontSize="16" Grid.ColumnSpan="1" TextTrimming="CharacterEllipsis" Padding="5,5,5,5"/>
        </Viewbox>
        <IEL:IELButtonImage x:FieldModifier="private" x:Name="IELButtonCloseInlay" Grid.ColumnSpan="1" Grid.Column="1" CornerRadius="5,5,5,5" CornerRadiusGuides="7.6,7.6,7.6,7.6" Margin="4,4,4,4" Width="27" Height="27"/>
    </Grid>
</Base:IELContainerBase>
