<Base:OPLNetworkElementViewerBase
    x:Class="OPLAPI.OIEL.UserElementsControl.Network.OPLNetworkMessage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:Base="clr-namespace:OPLAPI.OIEL.UserElementsControl.Base"
    xmlns:OIEL="clr-namespace:OPLAPI.OIEL.UserElementsControl"
    xmlns:IEL="clr-namespace:IEL.UserElementsControl;assembly=LibraryIEL"
    mc:Ignorable="d" PaletteElement="{DynamicResource LightBlue}" CornerRadius="5,5,5,5" FontFamily="{DynamicResource Deledda Open Regular}" SenderTextPoint="Point" SenderPadding="2,5,20,0" FontSize="14">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border x:FieldModifier="private" x:Name="BorderClipElements"/>
        <TextBlock x:FieldModifier="private" x:Name="TextBlockMessage" Text="Text" FontFamily="{DynamicResource Bree CYR var}" Margin="5,5,5,5" Grid.RowSpan="1" TextTrimming="WordEllipsis" TextWrapping="Wrap" Grid.Row="1" FontSize="15"/>
    </Grid>
</Base:OPLNetworkElementViewerBase>
