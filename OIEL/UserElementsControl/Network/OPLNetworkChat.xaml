<Base:OPLNetworkElementViewerBase
    x:Class="OPLAPI.OIEL.UserElementsControl.Network.OPLNetworkChat"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:Base="clr-namespace:OPLAPI.OIEL.UserElementsControl.Base"
    xmlns:OIEL="clr-namespace:OPLAPI.OIEL.UserElementsControl"
    xmlns:IEL="clr-namespace:IEL.UserElementsControl;assembly=LibraryIEL"
    mc:Ignorable="d" CornerRadius="5,5,5,5" FontFamily="{DynamicResource Bree CYR var}" PaletteElement="{DynamicResource Gray}" SenderTextPoint="Заголовок" SenderPadding="2,2,2,0" BorderThicknessTop="3">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>
        <TextBlock x:FieldModifier="internal" x:Name="TextBlockHead" Text="Вы:" Padding="3,0,3,3" HorizontalAlignment="Left" TextTrimming="CharacterEllipsis" Grid.ColumnSpan="1" FontSize="14"/>
        <Grid Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Image x:FieldModifier="internal" x:Name="ImageIconMessage" Grid.Column="1" Width="15" Margin="1,0,4,0"/>
            <TextBlock x:FieldModifier="private" x:Name="TextBlockCountFiles" Text="14" FontFamily="{DynamicResource Alphasano}" VerticalAlignment="Center" Grid.ColumnSpan="1" Grid.Column="0" FontSize="14"/>
        </Grid>
        <TextBlock x:FieldModifier="internal" x:Name="TextBlockEndMessage" Text="Файл(ы)" Padding="3,0,3,3" HorizontalAlignment="Left" TextTrimming="CharacterEllipsis" Grid.ColumnSpan="1" Grid.Column="2" Foreground="Black" Opacity="{Binding Opacity, ElementName=TextBlockHead}" FontSize="14"/>
    </Grid>
</Base:OPLNetworkElementViewerBase>
