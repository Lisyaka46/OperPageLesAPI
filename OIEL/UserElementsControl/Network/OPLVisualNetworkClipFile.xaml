<Base:NetworkClipElementBase
    x:Class="OPLAPI.OIEL.UserElementsControl.Network.OPLVisualNetworkClipFile"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:Base="clr-namespace:OPLAPI.OIEL.UserElementsControl.Base"
    xmlns:OIEL="clr-namespace:OPLAPI.OIEL.UserElementsControl;assembly=OPLAPI"
    xmlns:IEL="clr-namespace:IEL.UserElementsControl;assembly=LibraryIEL"
    mc:Ignorable="d">
    <Grid VerticalAlignment="Center" HorizontalAlignment="Left">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Rectangle x:Name="RectangleLoading" Width="36" Height="36" RadiusX="10" RadiusY="10" StrokeDashArray="28" StrokeDashCap="Round" Fill="#FF15634C" Grid.RowSpan="1" StrokeLineJoin="Round" StrokeMiterLimit="112" ClipToBounds="True" StrokeDashOffset="28" Grid.ColumnSpan="1" StrokeThickness="0" Margin="5,5,5,5">
            <Rectangle.Stroke>
                <RadialGradientBrush x:FieldModifier="private" x:Name="RadialGradientLoading" RadiusX="0.53" RadiusY="0.53" Center="0.35,0.5" GradientOrigin="0.5,0.5" Opacity="1">
                    <RadialGradientBrush.RelativeTransform>
                        <TransformGroup>
                            <ScaleTransform CenterY="0.5" CenterX="0.5"/>
                            <SkewTransform CenterX="0.5" CenterY="0.5"/>
                            <RotateTransform x:FieldModifier="private" x:Name="RotateGradientLoading" CenterX="0.5" CenterY="0.5" Angle="0"/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </RadialGradientBrush.RelativeTransform>
                    <GradientStop Color="{Binding Fill.Color, ElementName=RectangleLoading}" Offset="0.7"/>
                    <GradientStop x:Name="GradientStopLoadingIndicator" Color="White" Offset="0.9"/>
                </RadialGradientBrush>
            </Rectangle.Stroke>
        </Rectangle>
        <Image x:Name="IconLoadingFile" ClipToBounds="True" Width="25" Height="25" Grid.RowSpan="1" Grid.ColumnSpan="1"/>
        <Grid Grid.Row="0" Grid.Column="1" VerticalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock x:FieldModifier="private" x:Name="TextBlockNameFile" Text="File.jpg" FontFamily="{DynamicResource Bree CYR var}" Grid.RowSpan="1" Grid.Row="0" Padding="0,0,5,1"/>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <TextBlock x:FieldModifier="private" x:Name="TextBlockSizeFile" Text="4 MB" FontFamily="{DynamicResource RussianRail G Pro}" Grid.RowSpan="1" Padding="0,0,2,0" Margin="0,2,0,0" Grid.ColumnSpan="1"/>
                <TextBlock x:FieldModifier="private" x:Name="TextBlockProgress" Grid.Column="1" VerticalAlignment="Bottom" Padding="0,0,0,0.3" Width="50">
                <Run x:FieldModifier="private" x:Name="CurrentProgress" Text="100.00" BaselineAlignment="Bottom" FontFamily="{DynamicResource Alphasano}" FontSize="10"/>
                <Run Text="%" FontFamily="{DynamicResource Alphasano}" BaselineAlignment="Bottom" FontSize="10"/>
                </TextBlock>
            </Grid>
        </Grid>
    </Grid>
</Base:NetworkClipElementBase>
