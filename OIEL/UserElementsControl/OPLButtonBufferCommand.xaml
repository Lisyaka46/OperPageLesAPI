<Base:IELButtonBase
    x:Class="OPLAPI.OIEL.UserElementsControl.OPLButtonBufferCommand"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:Base="clr-namespace:IEL.UserElementsControl.Base;assembly=LibraryIEL"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" CornerRadius="5,5,5,5">
    <Grid x:Name="GridButton">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="TextBlockNumberCommand" HorizontalAlignment="Center" TextWrapping="Wrap" Text="#00" VerticalAlignment="Center" FontSize="8" FontWeight="Bold" TextAlignment="Right" Margin="2,2,2,2"/>
            <TextBlock x:Name="TextBlockButtonName" TextTrimming="WordEllipsis" Text="NameCommand" TextAlignment="Center" Foreground="Black" Focusable="True" TextWrapping="Wrap" ScrollViewer.HorizontalScrollBarVisibility="Hidden" ScrollViewer.VerticalScrollBarVisibility="Hidden" Grid.ColumnSpan="1" VerticalAlignment="Center" Grid.Row="0" Grid.Column="1" Padding="5,0,5,0"/>
        </Grid>
        <TextBlock x:Name="TextBlockButtonCommand" Text="Command" TextAlignment="Right" Foreground="Black" Focusable="True" TextWrapping="Wrap" ScrollViewer.HorizontalScrollBarVisibility="Hidden" ScrollViewer.VerticalScrollBarVisibility="Hidden" Grid.ColumnSpan="1" VerticalAlignment="Center" FontSize="8" TextTrimming="CharacterEllipsis" Grid.Row="2" MaxHeight="11" Margin="2,0,2,0"/>
    </Grid>
</Base:IELButtonBase>
