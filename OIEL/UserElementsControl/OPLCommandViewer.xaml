<Base:IELContainerBase
    x:Class="OPLAPI.OIEL.UserElementsControl.OPLCommandViewer"
    xmlns:Base="clr-namespace:IEL.UserElementsControl.Base;assembly=LibraryIEL"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:OPLAPI.OIEL.UserElementsControl"
    xmlns:IEL="clr-namespace:IEL.UserElementsControl;assembly=LibraryIEL"
    HorizontalContentAlignment="Stretch" HorizontalAlignment="Left">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border x:Name="BorderInfo" Grid.Row="0" BorderThickness="0,0,0,2" BorderBrush="Black">
            <Grid ClipToBounds="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <Rectangle x:Name="AsyncIndicator" Grid.ColumnSpan="2" VerticalAlignment="Top" StrokeThickness="0" Height="10" Opacity="0.8" RenderTransformOrigin="0.5,0.5" RadiusX="5" RadiusY="5" IsHitTestVisible="False" Width="10" HorizontalAlignment="Right" Margin="0,3,3,0">
                    <Rectangle.Fill>
                        <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.8,0.2" RadiusX="0.8" RadiusY="0.8">
                            <GradientStop Color="#FFFF7777"/>
                            <GradientStop Color="Red" Offset="1"/>
                        </RadialGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <IEL:IELButtonImage x:Name="IELButtonDeleteElement" Margin="4,4,4,4" PaletteElement="{DynamicResource Tangerine}" CornerRadius="5,5,5,5" MarginViewBox="1,1,1,1"/>
                <MediaElement x:Name="IndicatorLoading" Stretch="UniformToFill" IsHitTestVisible="False" Grid.ColumnSpan="1" Grid.Column="0" Width="14" Height="14" Source="/UI/Images/Media/Loading/LoadingDefault.mp4" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,-2,0" UnloadedBehavior="Manual">
                    <MediaElement.OpacityMask>
                        <RadialGradientBrush>
                            <GradientStop Color="Black" Offset="0.709"/>
                            <GradientStop Color="#00000000" Offset="0.844"/>
                        </RadialGradientBrush>
                    </MediaElement.OpacityMask>
                </MediaElement>
                <TextBlock x:Name="TextBlockNameCommand" FontFamily="{DynamicResource RussianRail G Pro}" VerticalAlignment="Center" Margin="0,0,2,0" IsHitTestVisible="False" Grid.Column="1" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" Text="Command"/>
            </Grid>
        </Border>
        <StackPanel x:FieldModifier="private" x:Name="Container" HorizontalAlignment="Left" Grid.Row="1">
            <TextBlock Text="sdf;kgjsd;flkgjs;dlfkgj;sldfkgjs;ldkfgjs;ldfkgjs;lfkgjs;dlfkgj" TextTrimming="CharacterEllipsis" TextWrapping="Wrap" LineStackingStrategy="BlockLineHeight"/>
        </StackPanel>
    </Grid>
</Base:IELContainerBase>
